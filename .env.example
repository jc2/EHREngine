# Django settings module to load
DJANGO_SETTINGS_MODULE=ehrengine.settings.dev

# Secret key — generate a unique value for any non-dev environment
DJANGO_SECRET_KEY=change-me-to-a-random-secret

# Postgres connection (host `db` matches the docker-compose service; use `localhost:5433` outside Docker)
DATABASE_URL=postgres://ehrengine:ehrengine_dev@db:5432/ehrengine_db

# Auto-created Django admin superuser
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_EMAIL=admin@example.com

# Pydantic Logfire token (optional; leave blank to disable export)
LOGFIRE_TOKEN=
